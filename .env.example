# SQLAlchemy (asyncpg) connection string to a PostGIS-enabled PostgreSQL database.
# IMPORTANT: do not commit real credentials. Put your real value in a local `.env`.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/cpde

# Optional (needed for MODIS LST via NASA CMR when downloading protected assets)
# EARTHDATA_USERNAME=
# EARTHDATA_PASSWORD=
